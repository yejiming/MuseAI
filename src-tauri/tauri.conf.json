{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MuseAI",
  "mainBinaryName": "MuseAI",
  "version": "0.6.2",
  "identifier": "com.yejiming.tauri-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MuseAI",
        "width": 1280,
        "height": 860
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/skills": "skills"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      },
      "wix": {
        "template": "windows/main.wxs"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
